<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemDetailPage"
              xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
              xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
              xmlns:sys="clr-namespace:System;assembly=netstandard"
              Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Item title -->
            <Label Text="{Binding SelectedItem.Title}"
                   FontSize="24"
                   FontAttributes="Bold" />

            <!-- Item description -->
            <Label Text="{Binding SelectedItem.Description}"
                   FontSize="16" />

            <!-- Item category -->
            <Label Text="{Binding SelectedItem.Category}"
                   FontSize="16" />

            <!-- Item location -->
            <Label Text="{Binding SelectedItem.DisplayLocation}"
                   FontSize="16"
                   TextColor="Gray" />

            <!-- Price per day -->
            <Label Text="{Binding SelectedItem.DailyRate, StringFormat='£{0:F2} per day'}"
                   FontSize="18"
                   FontAttributes="Bold" />

            <!-- Date pickers - only visible for rental request -->
            <VerticalStackLayout Spacing="8"
                                 IsVisible="{Binding CanRequestRental}">

                <Label Text="Select Rental Dates"
                       FontSize="16"
                       FontAttributes="Bold" />

                <Label Text="Start Date:" />
                <DatePicker Date="{Binding StartDate}"
                            MinimumDate="{x:Static sys:DateTime.Today}"
                            Format="dd/MM/yyyy" />

                <Label Text="End Date:" />
                <DatePicker Date="{Binding EndDate}"
                            MinimumDate="{x:Static sys:DateTime.Today}"
                            Format="dd/MM/yyyy" />

            </VerticalStackLayout>

            <!-- Request rental button, only visible for items owned by other users -->
            <Button Text="Request Rental"
                    Command="{Binding RequestRentalCommand}"
                    IsVisible="{Binding CanRequestRental}" />

            <!-- Edit button, only visible to the item owner -->
            <Button Text="Edit Item"
                    Command="{Binding GoToEditItemCommand}"
                    IsVisible="{Binding IsOwner}" />

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>