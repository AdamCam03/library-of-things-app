<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.MyItemsPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <Grid Padding="20" RowDefinitions="Auto,Auto,Auto,*">

        <!-- Add item button -->
        <Button Grid.Row="0"
                Text="List an Item"
                Command="{Binding GoToCreateItemCommand}"
                Margin="0,0,0,10" />

        <!-- Rental requests button -->
        <Button Grid.Row="1"
                Text="View Rental Requests"
                Command="{Binding GoToRentalRequestsCommand}"
                Margin="0,0,0,10" />

        <!-- Error message -->
        <Label Grid.Row="2"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               Margin="0,0,0,10" />

        <!-- Item list -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">

            <!-- Message shown when user has no listed items -->
            <CollectionView.EmptyView>
                <Label Text="You have not listed any items yet."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- Item card -->
                    <Border Margin="0,5"
                            Padding="15"
                            Stroke="LightGray"
                            StrokeThickness="1">

                        <VerticalStackLayout Spacing="8">

                            <Label Text="{Binding Title}"
                                   FontSize="20"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                   FontSize="14" />

                            <Label Text="{Binding Category}"
                                   FontSize="14" />

                            <Label Text="{Binding LocationName}"
                                   FontSize="14" />

                            <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>