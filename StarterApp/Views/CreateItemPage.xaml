<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.CreateItemPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15">

            <!-- Item title -->
            <Entry Placeholder="Item title"
                   Text="{Binding ItemTitle}" />

            <!-- Description -->
            <Editor Placeholder="Description"
                    Text="{Binding ItemDescription}"
                    HeightRequest="100" />

            <!-- Category picker -->
            <Picker Title="Select Category"
                    SelectedItem="{Binding SelectedCategory}">
                <Picker.Items>
                    <x:String>Tools</x:String>
                    <x:String>Garden</x:String>
                    <x:String>Camping</x:String>
                    <x:String>Sports</x:String>
                    <x:String>Electronics</x:String>
                    <x:String>Games</x:String>
                    <x:String>DIY</x:String>
                    <x:String>Cycling</x:String>
                    <x:String>Music</x:String>
                    <x:String>Outdoors</x:String>
                </Picker.Items>
            </Picker>

            <!-- Location picker -->
            <Picker Title="Select Location"
                    SelectedItem="{Binding SelectedLocation}">
                <Picker.Items>
                    <x:String>Edinburgh</x:String>
                    <x:String>Glasgow</x:String>
                    <x:String>Paisley</x:String>
                </Picker.Items>
            </Picker>

            <!-- Daily rate -->
            <Entry Placeholder="Daily rate"
                   Text="{Binding ItemDailyRate}"
                   Keyboard="Numeric" />

            <!-- Error message -->
            <Label Text="{Binding ErrorMessage}"
                   TextColor="Red" />

            <!-- Create item button -->
            <Button Text="Create Item"
                    Command="{Binding CreateItemCommand}" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>