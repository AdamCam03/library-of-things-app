<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <!-- Grid layout to structure page -->
    <Grid RowDefinitions="Auto,Auto,Auto,*">

        <!-- Top buttons row -->
        <HorizontalStackLayout Grid.Row="0" Spacing="10" Margin="10">

            <!-- Button to navigate to Create Item page -->
            <Button Text="List an Item"
                    Command="{Binding GoToCreateItemCommand}" />

            <!-- Button to navigate to Rental Requests page -->
            <Button Text="My Rentals"
                    Command="{Binding GoToRentalRequestsCommand}" />

        </HorizontalStackLayout>

        <!-- Displays error messages -->
        <Label Grid.Row="1"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               Margin="10" />

        <!-- Items list -->
        <CollectionView Grid.Row="3"
                        ItemsSource="{Binding Items}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">

            <!-- Empty message -->
            <CollectionView.EmptyView>
                <Label Text="No items available yet. List an item to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <!-- Item card -->
                    <Border Margin="10"
                            Padding="15"
                            Stroke="LightGray"
                            StrokeThickness="1">

                        <VerticalStackLayout Spacing="8">

                            <Label Text="{Binding Title}"
                                   FontSize="20"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                   FontSize="14" />

                            <Label Text="{Binding Category}"
                                   FontSize="14" />

                            <Label Text="{Binding LocationName}"
                                   FontSize="14" />

                            <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                        </VerticalStackLayout>
                    </Border>

                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>