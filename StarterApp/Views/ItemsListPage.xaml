<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">

        <!-- List an Item button -->
        <Button Grid.Row="0"
                Text="List an Item"
                Command="{Binding GoToCreateItemCommand}"
                Margin="10,10,10,0" />

        <!-- My Rentals button -->
        <Button Grid.Row="1"
                Text="My Rentals"
                Command="{Binding GoToRentalRequestsCommand}"
                Margin="10,5,10,0" />

        <!-- Displays error messages -->
        <Label Grid.Row="2"
               Text="{Binding ErrorMessage}"
               TextColor="Red"
               Margin="10" />

        <!-- Items list -->
        <CollectionView Grid.Row="4"
                        ItemsSource="{Binding Items}"
                        SelectionMode="Single"
                        SelectionChanged="OnSelectionChanged">

            <CollectionView.EmptyView>
                <Label Text="No items available yet. List an item to get started."
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="10,5"
                            Padding="15"
                            Stroke="LightGray"
                            StrokeThickness="1">
                        <VerticalStackLayout Spacing="8">

                            <Label Text="{Binding Title}"
                                   FontSize="18"
                                   FontAttributes="Bold" />

                            <Label Text="{Binding Description}"
                                   FontSize="14"
                                   TextColor="Gray" />

                            <Label Text="{Binding Category}"
                                   FontSize="14"
                                   TextColor="Gray" />

                            <Label Text="{Binding DisplayLocation}"
                                   FontSize="14"
                                   TextColor="Gray" />

                            <Label Text="{Binding DailyRate, StringFormat='£{0:F2} per day'}"
                                   FontSize="16"
                                   FontAttributes="Bold" />

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>